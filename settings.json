{
  "cleanupPeriodDays": 3650,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_WORKFLOWS": "1",
    "DISABLE_GROWTHBOOK": "1",
    "PYTHONUTF8": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "WebFetch(*)",
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Task(*)",
      "Skill(*)",
      "mcp__claude-in-chrome",
      "mcp__claude_ai_Google_Drive",
      "mcp__claude_ai_Read_AI",
      "mcp__claude_ai_Vercel",
      "mcp__claude_ai_Notion",
      "mcp__supabase",
      "mcp__plugin_claude-mem_mcp-search",
      "mcp__plugin_cloudflare_cloudflare-api",
      "mcp__plugin_cloudflare_cloudflare-bindings",
      "mcp__plugin_cloudflare_cloudflare-builds",
      "mcp__plugin_cloudflare_cloudflare-docs",
      "mcp__plugin_cloudflare_cloudflare-observability",
      "mcp__plugin_context7_context7",
      "mcp__plugin_playwright_playwright",
      "mcp__plugin_superpowers-chrome_chrome"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -r *)",
      "Bash(rmdir *)",
      "Bash(mv *)",
      "Bash(del *)",
      "Bash(shutdown *)",
      "Bash(format *)",
      "Bash(reboot *)"
    ],
    "ask": [
      "Bash(git push --force *)",
      "Bash(git rebase *)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/careful_guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/research_guard.py\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/stans/.claude/hooks/claude-mem-port-sync.sh\"",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/stans/.claude/hooks/fix-claude-mem-windows.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/stans/.claude/hooks/claude-mem-sync.mjs\" download",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"C:/Users/stans/.claude/hooks/claude-mem-context.sh\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/twify-session-name.py\"",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/stans/.claude/hooks/claude-mem-sync.mjs\" upload",
            "timeout": 120
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"C:/Users/stans/.claude/hooks/twify-session-name.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://localhost:19280/"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash C:/Users/stans/.claude/statusline.sh",
    "padding": 1
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "csharp-lsp@claude-plugins-official": true,
    "explanatory-output-style@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": true,
    "kotlin-lsp@claude-plugins-official": true,
    "learning-output-style@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "php-lsp@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "double-shot-latte@superpowers-marketplace": false,
    "episodic-memory@superpowers-marketplace": false,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "superpowers-chrome@superpowers-marketplace": true,
    "claude-session-driver@superpowers-marketplace": false,
    "claude-mem@thedotmack": true,
    "zeabur@zeabur": true,
    "project-sweep@stan-local-plugins": true,
    "document-skills@anthropic-agent-skills": true,
    "superpowers@superpowers-marketplace": true,
    "cloudflare@cloudflare": true,
    "superpowers@claude-plugins-official": true,
    "claude-api@anthropic-agent-skills": true,
    "playwright@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "zeabur": {
      "source": {
        "source": "github",
        "repo": "zeabur/agent-skills"
      }
    },
    "stan-local-plugins": {
      "source": {
        "source": "directory",
        "path": "C:\\Users\\stans\\Projects\\project-sweep-plugin"
      }
    },
    "shyuan-marketplace": {
      "source": {
        "source": "github",
        "repo": "shyuan/shyuan-marketplace"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "cloudflare": {
      "source": {
        "source": "github",
        "repo": "cloudflare/skills"
      }
    }
  },
  "language": "中文",
  "effortLevel": "medium",
  "autoUpdatesChannel": "latest",
  "autoDreamEnabled": true,
  "skipWorkflowUsageWarning": true,
  "theme": "light",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "voiceEnabled": true
}
